{
  "name": "pureframework/pure-framework",
  "description": "Thin PHP framework: router, DB, forms, constraints, templates",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/pureframework/pure-framework",
  "keywords": [
    "php",
    "framework",
    "router",
    "pdo",
    "forms",
    "validation",
    "templates"
  ],
  "support": {
    "issues": "https://github.com/pureframework/pure-framework/issues",
    "source": "https://github.com/pureframework/pure-framework"
  },
  "autoload": {
    "psr-4": {
      "PureFramework\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "PureFramework\\Tests\\": "tests/"
    },
    "files": [
      "stubs/globals.stub.php"
    ]
  },
  "bin": [
    "bin/pure-generate-classes",
    "bin/pure-new-site"
  ],
  "scripts": {
    "test": "phpunit",
    "test:smoke": "php tests/smoke-test.php"
  },
  "authors": [
    {
      "name": "Jonathan Sharp"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "10.5"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.4.x-dev"
    }
  }
}
